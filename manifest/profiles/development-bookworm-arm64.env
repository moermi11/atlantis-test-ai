# Sprint 1 generic development profile.
# These are generic build inputs for a device-agnostic rootfs artifact.

ATLANTIS_PROFILE_NAME="development-bookworm-arm64"
ATLANTIS_PROFILE_KIND="generic"

ATLANTIS_SUITE="bookworm"
ATLANTIS_ARCH="arm64"
ATLANTIS_MMDEBSTRAP_VARIANT="minbase"
ATLANTIS_MIRROR="https://deb.debian.org/debian"
ATLANTIS_SECURITY_MIRROR="http://security.debian.org/debian-security"

ATLANTIS_ROOTFS_DIR="out/rootfs/development-bookworm-arm64"
ATLANTIS_REPO_DIR="out/repo/development-bookworm-arm64"
ATLANTIS_PACKAGE_ARTIFACT_DIR="out/packages/development-bookworm-arm64"

ATLANTIS_PACKAGE_LISTS="build/mmdebstrap/packages/base.list build/mmdebstrap/packages/phosh.list"
ATLANTIS_GENERIC_PACKAGES="atlantis-base,atlantis-branding,atlantis-shell"

# Future device-specific inputs stay explicit and unset in the generic profile.
ATLANTIS_DEVICE_ID=""
ATLANTIS_DEVICE_PACKAGE=""
ATLANTIS_BOOT_ARTIFACT_DIR=""
