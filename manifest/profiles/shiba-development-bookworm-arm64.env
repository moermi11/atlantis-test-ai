# Sprint 2 preparation profile for Google Pixel 8 (shiba).
# This profile layers on the generic development profile and keeps
# device-oriented inputs explicit without claiming Pixel 8 boot support.

. "${ATLANTIS_REPO_ROOT}/manifest/profiles/development-bookworm-arm64.env"

ATLANTIS_PROFILE_NAME="shiba-development-bookworm-arm64"
ATLANTIS_PROFILE_KIND="device"

# Generic build inputs
# Inherited from development-bookworm-arm64.env:
# - suite, architecture, mirrors, and mmdebstrap variant
# - generic rootfs artifact output path
# - generic package feed output path
# - generic package-list inputs
# - generic Atlantis package set

# Device-specific userspace inputs
ATLANTIS_DEVICE_ID="google-shiba"
ATLANTIS_DEVICE_PACKAGE="atlantis-device-google-shiba"
ATLANTIS_DEVICE_PACKAGE_SOURCE_DIR="packages/atlantis-device-google-shiba"
ATLANTIS_DEVICE_STAGE_DIR="out/device/shiba-development-bookworm-arm64"

# Boot-artifact staging contract
# - compose stage output stays separate from the boot-artifact staging directory
# - kernel and initramfs remain explicit external inputs until real artifacts exist
ATLANTIS_KERNEL_ARTIFACT=""
ATLANTIS_INITRAMFS_ARTIFACT=""
ATLANTIS_BOOT_ARTIFACT_DIR="out/boot/shiba-development-bookworm-arm64"

# Installer-preparation contract
# - installer preparation consumes the staged boot-artifact directory
# - installer preparation remains reviewable and non-destructive
ATLANTIS_INSTALLER_PREP_DIR="out/installer/shiba-development-bookworm-arm64"

# Structured flashing-decision and command-plan contract
# - flashing decisions stay as explicit review files until they are resolved truthfully
# - command-plan generation consumes installer-preparation output plus the decision files
# - command-plan output remains a review boundary, not an execution boundary
ATLANTIS_FLASHING_DECISION_DIR="installer/shiba/decisions"
ATLANTIS_COMMAND_PLAN_DIR="out/command-plan/shiba-development-bookworm-arm64"

# Evidence-bundle contract
# - evidence capture stays read-only and non-destructive
# - evidence bundles help review the flashing-decision files without overwriting them
ATLANTIS_EVIDENCE_BUNDLE_DIR="out/evidence/shiba-development-bookworm-arm64"

# Decision review/apply contract
# - review output stays separate from live decision files
# - apply requires an explicit reviewed step before live decision files change
ATLANTIS_DECISION_REVIEW_DIR="out/decision-review/shiba-development-bookworm-arm64"
ATLANTIS_DECISION_REVIEW_STATUS_FILE="installer/shiba/decisions/review-status.env"

# Readiness, operator-session, and execution contract
# - readiness stays a guarded safety boundary only
# - the operator session bundle stays a preparation boundary only
# - the execution harness defaults to dry-run and writes an auditable session ledger
ATLANTIS_READINESS_DIR="out/readiness/shiba-development-bookworm-arm64"
ATLANTIS_SESSION_BUNDLE_DIR="out/session-bundle/shiba-development-bookworm-arm64"
ATLANTIS_EXECUTION_DIR="out/execution/shiba-development-bookworm-arm64"
